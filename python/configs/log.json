{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "standardFormatter": {
            "format": "%(asctime)s %(levelname)s %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        }
    },
    "handlers": {
        "exitOnErrorHandler": {
            "class": "logutil.ExitOnErrorHandler",
            "formatter": "standardFormatter",
            "filename": "",
            "mode": "a"
        }
    },
    "loggers": {
        "root": {
            "level": "INFO",
            "handlers": ["exitOnErrorHandler"],
            "propagate": false
        }, 
        "googleapiclient.discovery_cache": {
            "level": "ERROR",
            "handlers": ["exitOnErrorHandler"],
            "propagate": false
        }
    }
}