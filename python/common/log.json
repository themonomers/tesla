{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "standardFormatter": {
            "format": "%(asctime)s %(levelname)s %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        }
    },
    "handlers": {
        "exitOnErrorHandler": {
            "class": "logutil.ExitOnErrorHandler",
            "level": "ERROR",
            "formatter": "standardFormatter",
            "filename": "/home/pi/tesla/python/tesla.log",
            "mode": "a"
        },
        "standardHandler": {
            "class": "logging.FileHandler",
            "level": "INFO",
            "formatter": "standardFormatter",
            "filename": "/home/pi/tesla/python/tesla.log",
            "mode": "a"
        }
    },
    "loggers": {
        "root": {
            "level": "INFO",
            "handlers": ["exitOnErrorHandler", "standardHandler"],
            "propagate": false
        }
    }
}